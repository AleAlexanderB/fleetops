# ══════════════════════════════════════════════════
# AB Construcciones — Variables de entorno
# 1. Copiar como:  cp .env.example .env
# 2. Completar los valores (ver SECRETOS.md)
# 3. NUNCA commitear el .env real al repositorio
# ══════════════════════════════════════════════════

# ── Empresas RedGPS ───────────────────────────────
# Empresa 1
EMPRESA_1_NOMBRE=Corralon el Mercado
EMPRESA_1_APIKEY=
EMPRESA_1_USERNAME=
EMPRESA_1_PASSWORD=

# Empresa 2
EMPRESA_2_NOMBRE=VIAP
EMPRESA_2_APIKEY=
EMPRESA_2_USERNAME=
EMPRESA_2_PASSWORD=

# Compat (mismos datos que empresa 1)
REDGPS_APIKEY=
REDGPS_USERNAME=
REDGPS_PASSWORD=
REDGPS_BASE_URL=http://api.service24gps.com/api/v1

# ── URLs ──────────────────────────────────────────
VITE_API_URL=http://157.245.219.73:8077

# ── Base de datos MySQL ───────────────────────────
DATABASE_URL=mysql://fleetops:CAMBIAR@db:3306/fleetops
DB_ROOT_PASSWORD=CAMBIAR
DB_USER=fleetops
DB_PASSWORD=CAMBIAR

# ── Intervalos de polling ─────────────────────────
POLL_POSICIONES_MS=30000
POLL_ALERTAS_MS=300000
POLL_VEHICULOS_MS=3600000
POLL_GEOCERCAS_MS=3600000

# ── Servidor ──────────────────────────────────────
PORT=8077
NODE_ENV=production
CORS_ORIGIN=*

# ── Seguridad ─────────────────────────────────────
# JWT para autenticación de usuarios en FleetOPS
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_LARGO

# API key para service-to-service (puede quedar vacío en red interna)
API_KEY=

# ── Integration Gateway ───────────────────────────
# URL del Integration Gateway (antes gps-gateway, ahora repo propio).
# En dev local standalone: http://host.docker.internal:3100
# En compose con red ab-ecosystem: http://integration-gateway:3100
GATEWAY_URL=http://integration-gateway:3100

# API key del gateway (debe coincidir con la configurada en el repo
# integration-gateway). Vacío = sin auth, útil en dev local.
GATEWAY_API_KEY=
