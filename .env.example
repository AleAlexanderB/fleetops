# ══════════════════════════════════════════════════
# FleetOPS — Variables de entorno
# Copiar como .env y completar antes de docker compose up
# NUNCA commitear el .env real al repositorio
# ══════════════════════════════════════════════════

# ── RedGPS (obligatorio) ──────────────────────────
REDGPS_APIKEY=TU_APIKEY_AQUI
REDGPS_USERNAME=tu_usuario@abconstrucciones.com
REDGPS_PASSWORD=tu_password_aqui
REDGPS_BASE_URL=http://api.redgps.com/api/v1

# ── IP del servidor Hyper-V ───────────────────────
VITE_API_URL=http://192.168.1.100:8077

# ── Base de datos MySQL (Fase 3) ──────────────────
# En Docker: el host es "db" (nombre del servicio)
# En desarrollo local: localhost
DATABASE_URL=mysql://fleetops:fleetops_2024@db:3306/fleetops

# Para desarrollo local sin Docker:
# DATABASE_URL=mysql://fleetops:fleetops_2024@localhost:3306/fleetops

# ── Intervalos de polling ─────────────────────────
POLL_POSICIONES_MS=30000
POLL_ALERTAS_MS=300000
POLL_VEHICULOS_MS=3600000
POLL_GEOCERCAS_MS=3600000

# ── Servidor ──────────────────────────────────────
PORT=8077
NODE_ENV=production
CORS_ORIGIN=*

# ── Credenciales MySQL ────────────────────────────
DB_ROOT_PASSWORD=fleetops_root_2024
DB_USER=fleetops
DB_PASSWORD=fleetops_2024

# ── Seguridad de API ──────────────────────────────────────────────────────────
# Clave para proteger los endpoints de la API.
# Si se deja vacío, la API es pública (válido en LAN interna sin exposición externa).
# Si se define, todas las rutas requieren el header: X-Api-Key: <valor>
API_KEY=
