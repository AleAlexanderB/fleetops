# ══════════════════════════════════════════════════
# FleetOPS v9 — Variables de entorno
# Copiar este archivo como .env y completar los valores
# NUNCA commitear el .env real al repositorio
# ══════════════════════════════════════════════════

# ── Multi-empresa RedGPS (v9) ────────────────────
# Definir hasta 20 empresas con sus credenciales.
# Si no se definen EMPRESA_N_, se usan las variables legacy REDGPS_*.

# EMPRESA_1_NOMBRE=Mi Empresa
# EMPRESA_1_APIKEY=xxx
# EMPRESA_1_USERNAME=usuario@ejemplo.com
# EMPRESA_1_PASSWORD=xxx

# EMPRESA_2_NOMBRE=Otra Empresa
# EMPRESA_2_APIKEY=yyy
# EMPRESA_2_USERNAME=otro@ejemplo.com
# EMPRESA_2_PASSWORD=yyy

# ── RedGPS (legacy — fallback si no hay EMPRESA_N_) ──
REDGPS_APIKEY=TU_APIKEY_AQUI
REDGPS_USERNAME=tu_usuario@abconstrucciones.com
REDGPS_PASSWORD=tu_password_aqui
REDGPS_BASE_URL=http://api.service24gps.com/api/v1

# ── Intervalos de polling (en milisegundos) ───────
POLL_POSICIONES_MS=30000
POLL_ALERTAS_MS=300000
POLL_VEHICULOS_MS=3600000
POLL_GEOCERCAS_MS=3600000

# ── Deteccion de viajes ──────────────────────────
MINUTOS_PARADA_DESTINO=5

# ── Servidor ──────────────────────────────────────
PORT=8077
NODE_ENV=production
CORS_ORIGIN=*

# ── Base de datos ─────────────────────────────────
# DATABASE_URL=mysql://fleetops:password@localhost:3306/fleetops

# ── Frontend (para el build de Vite) ─────────────
VITE_API_URL=http://192.168.1.100:8077

# ── Seguridad de API ─────────────────────────────
API_KEY=
